# ── Required ──────────────────────────────────────────────
PORT=4402
NETWORK=solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ── Keypair (use ONE of these three methods) ──────────────
# Method 1 (MOST SECURE): Encrypted keypair + separate passphrase
#   Run: node encrypt-keypair.js facilitator-keypair.json 'your-passphrase'
# FACILITATOR_KEYPAIR_ENCRYPTED=<base64 blob>
# KEYPAIR_PASSPHRASE=<your passphrase>

# Method 2: Raw JSON array in env var (for Coolify/Railway)
# FACILITATOR_KEYPAIR_JSON=[1,2,3,...,64]

# Method 3: Path to a file on disk (local dev only)
# FACILITATOR_KEYPAIR_PATH=/path/to/keypair.json

# ── Allowlists ────────────────────────────────────────────
ALLOWED_NETWORKS=solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp
ALLOWED_ASSETS=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# ALLOWED_PAY_TO=YourWallet1,YourWallet2

# ── Transaction Inspection ────────────────────────────────
MAX_COMPUTE_UNITS=200000
MAX_PRIORITY_FEE_MICROLAMPORTS=50000
LOW_BALANCE_THRESHOLD_SOL=0.05

# ── Alerts (Discord/Slack webhook for low-balance alerts) ─
# ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGIN=*
